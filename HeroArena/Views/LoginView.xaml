<Window x:Class="HeroArena.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hero Arena — Connexion"
        Height="480" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource DarkBgBrush}">

	<Grid Margin="40">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
                   Text="HERO ARENA"
                   Style="{StaticResource TitleText}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6"/>

		<TextBlock Grid.Row="1"
                   Text="Entrez dans l'arène"
                   Style="{StaticResource SubText}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

		<TextBlock Grid.Row="2"
                   Text="Nom d'utilisateur"
                   Style="{StaticResource BodyText}"
                   Margin="0,0,0,6"/>

		<TextBox Grid.Row="3"
                 x:Name="UsernameBox"
                 Style="{StaticResource DarkInput}"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,16"/>

		<TextBlock Grid.Row="4"
                   Text="Mot de passe"
                   Style="{StaticResource BodyText}"
                   Margin="0,0,0,6"/>

		<PasswordBox Grid.Row="5"
                     x:Name="PasswordBox"
                     Style="{StaticResource DarkPasswordBox}"
                     Margin="0,0,0,16"/>

		<TextBlock Grid.Row="6"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource DangerBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

		<StackPanel Grid.Row="7">
			<Button Content="Se connecter"
                    Click="BtnLogin_Click"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,10"/>

			<Button Content="Créer un compte"
                    Click="BtnRegister_Click"
                    Style="{StaticResource SpellButton}"
                    Margin="0,0,0,10"/>

			<Button Content="Paramètres BDD"
                    Command="{Binding OpenSettingsCommand}"
                    Style="{StaticResource DangerButton}"/>
		</StackPanel>
	</Grid>
</Window>